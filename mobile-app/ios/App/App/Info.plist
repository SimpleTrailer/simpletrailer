<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>de</string>
	<key>CFBundleDisplayName</key>
	<string>SimpleTrailer</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- Privacy: Standort -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SimpleTrailer nutzt deinen Standort, um Anhänger in deiner Nähe zu finden und Routen zur Abholung zu zeigen.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>SimpleTrailer nutzt deinen Standort, um Anhänger in deiner Nähe zu finden.</string>

	<!-- Privacy: Kamera (für Schadensfotos / Pre-Check / Return) -->
	<key>NSCameraUsageDescription</key>
	<string>SimpleTrailer nutzt die Kamera, damit du Fotos vom Anhänger-Zustand vor und nach der Miete aufnehmen kannst.</string>

	<!-- Privacy: Foto-Bibliothek (Foto-Auswahl als Alternative zur Kamera) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SimpleTrailer kann auf deine Fotos zugreifen, damit du existierende Bilder vom Anhänger-Zustand hochladen kannst.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>SimpleTrailer kann aufgenommene Anhänger-Fotos in deiner Bibliothek speichern.</string>

	<!-- Privacy: Microphone (oft von Apple zusammen mit Camera erwartet) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>SimpleTrailer benötigt das Mikrofon nicht aktiv. Diese Berechtigung wird nicht angefragt.</string>

	<!-- Push-Notifications-Vorbereitung -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- Apple Pay / Stripe Wallet (Merchant-ID muss bei Apple registriert sein) -->
	<!-- <key>com.apple.developer.in-app-payments</key>
	<array>
		<string>merchant.de.simpletrailer.app</string>
	</array> -->

	<!-- Deep-Links via simpletrailer:// und Universal Links für simpletrailer.de -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>de.simpletrailer.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>simpletrailer</string>
			</array>
		</dict>
	</array>

	<!-- App Transport Security: alles HTTPS -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>

	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>

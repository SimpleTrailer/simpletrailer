{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/anomaly-check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/weekly-advisor",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/social-media-generator",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/bug-triager",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/competitor-watcher",
      "schedule": "0 9 1 * *"
    }
  ],
  "headers": [
    {
      "source": "/(analytics|native-bridge|chat-widget|sw).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}

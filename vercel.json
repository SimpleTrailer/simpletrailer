{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/anomaly-check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/weekly-advisor",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/social-media-generator",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/bug-triager",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/competitor-watcher",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-ratgeber-generator",
      "schedule": "0 8 * * 3"
    },
    {
      "path": "/api/cron/midweek-check",
      "schedule": "0 12 * * 3"
    },
    {
      "path": "/api/cron/legal-quarterly-audit",
      "schedule": "0 9 1 1,4,7,10 *"
    },
    {
      "path": "/api/cron/termin-watcher",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/booking-watcher",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/tuev-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/budget-optimizer",
      "schedule": "0 19 * * 0"
    }
  ],
  "headers": [
    {
      "source": "/(analytics|native-bridge|chat-widget|sw).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}

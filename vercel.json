{
  "cleanUrls": true,
  "trailingSlash": false,
  "regions": ["fra1"],
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/anomaly-check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/weekly-advisor",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/social-media-generator",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/bug-triager",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/competitor-watcher",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-ratgeber-generator",
      "schedule": "0 8 * * 3"
    },
    {
      "path": "/api/cron/midweek-check",
      "schedule": "0 12 * * 3"
    },
    {
      "path": "/api/cron/legal-quarterly-audit",
      "schedule": "0 9 1 1,4,7,10 *"
    },
    {
      "path": "/api/cron/termin-watcher",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/booking-watcher",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/tuev-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/budget-optimizer",
      "schedule": "0 19 * * 0"
    },
    {
      "path": "/api/cron/sync-tracker-positions",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/tracker-watchdog",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/confirm-pending-returns",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/review-request",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/quarterly-code-reminder",
      "schedule": "0 9 1 1,4,7,10 *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(analytics|native-bridge|chat-widget|sw).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}

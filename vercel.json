{
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/booking", "destination": "/booking.html" },
    { "source": "/return", "destination": "/return.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/precheck", "destination": "/precheck.html" }
  ]
}
